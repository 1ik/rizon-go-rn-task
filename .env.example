# Copy to .env and adjust. Defaults work with docker-compose.deps.yml.

# Server (optional)
# PORT=8080
# BASE_URL=http://localhost:8080

# Database (defaults match docker-compose.deps.yml)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=rizon
# DB_PASSWORD=rizon_dev_password
# DB_NAME=rizon_db
# DB_SSLMODE=disable

# Redis (optional; defaults: localhost:6379)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# RabbitMQ (optional; defaults match docker-compose.deps.yml)
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=rizon
# RABBITMQ_PASSWORD=rizon_dev_password

# Required only when running the worker (task worker:run)
# EMAIL_USERNAME=your-smtp-username
# EMAIL_PASSWORD=your-smtp-password
# EMAIL_FROM=your-from@example.com
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# Auth (optional; dev defaults exist)
# EMAIL_AUTH_SALT=...
# JWT_SECRET=...

# Rate limiting (optional)
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60

# Frontend codegen (optional; used by task rn:codegen)
# GRAPHQL_ENDPOINT=http://localhost:8080/graphql
